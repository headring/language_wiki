{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Normalized Open Anki JLPT word",
  "type": "object",
  "required": ["schemaVersion", "source", "word"],
  "properties": {
    "schemaVersion": { "const": "jlpt.open-anki.normalized.v1" },
    "source": {
      "type": "object",
      "required": ["repo", "level", "fileName", "rowNumber", "sourceUrl"],
      "properties": {
        "repo": { "type": "string" },
        "level": { "type": "string" },
        "fileName": { "type": "string" },
        "rowNumber": { "type": "integer" },
        "sourceUrl": { "type": "string" }
      }
    },
    "word": {
      "type": "object",
      "required": ["expression", "reading", "meaningEnRaw", "tags", "guid"],
      "properties": {
        "expression": { "type": "string" },
        "reading": { "type": "string" },
        "meaningEnRaw": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "guid": { "type": "string" }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}

