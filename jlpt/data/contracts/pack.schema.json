{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JLPT app import pack",
  "type": "object",
  "required": ["schemaVersion", "source", "words"],
  "properties": {
    "schemaVersion": { "const": "jlpt.pack.v1" },
    "source": {
      "type": "object",
      "required": ["repo", "branch", "generatedAt"],
      "properties": {
        "repo": { "type": "string" },
        "branch": { "type": "string" },
        "generatedAt": { "type": "string" }
      }
    },
    "words": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["wordId", "jlptLevel", "sequenceInLevel", "kanji", "readingHiragana", "meaningKoVariants", "source"],
        "properties": {
          "wordId": { "type": "string" },
          "jlptLevel": { "type": "string" },
          "sequenceInLevel": { "type": "integer" },
          "kanji": { "type": "string" },
          "readingHiragana": { "type": "string" },
          "meaningKoVariants": { "type": "array", "items": { "type": "string" } },
          "exampleJp": { "type": ["string", "null"] },
          "exampleKo": { "type": ["string", "null"] },
          "source": { "type": "object" }
        }
      }
    }
  }
}

