{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JLPT translation task",
  "type": "object",
  "required": ["taskId", "kind", "sourceId", "input", "outputSchema"],
  "properties": {
    "taskId": { "type": "string" },
    "kind": { "const": "translate-meaning" },
    "sourceId": { "type": "string" },
    "level": { "type": "string" },
    "input": {
      "type": "object",
      "required": ["expression", "reading", "meaningEnRaw", "tags", "guid"],
      "properties": {
        "expression": { "type": "string" },
        "reading": { "type": "string" },
        "meaningEnRaw": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "guid": { "type": "string" }
      }
    },
    "outputSchema": {
      "type": "object",
      "required": ["meaningKoVariants", "notes"],
      "properties": {
        "meaningKoVariants": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}

